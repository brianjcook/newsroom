RewriteEngine On

# Force the canonical host first.
RewriteCond %{HTTP_HOST} !^www\.warehamtimes\.com$ [NC]
RewriteRule ^ https://www.warehamtimes.com%{REQUEST_URI} [L,R=301]

# Then force HTTPS on the canonical host.
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://www.warehamtimes.com%{REQUEST_URI} [L,R=301]

DirectoryIndex index.php

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^calendar/?$ calendar.php [L,QSA]
RewriteRule ^status/?$ status.php [L,QSA]
RewriteRule ^desk/?$ editorial.php [L,QSA]
RewriteRule ^events/([0-9]+)/([^/]+)/?$ event.php?id=$1 [L,QSA]
RewriteRule ^events/([0-9]+)/?$ event.php?id=$1 [L,QSA]
RewriteRule ^stories/([^/]+)/?$ story.php?slug=$1 [L,QSA]
